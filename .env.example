# ============================================================
# Bots Battle — Environment Variables Example
# Copy to .env.local and fill in your values.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/bots_battle

# ── Auth (NextAuth.js) ───────────────────────────────────────
NEXTAUTH_URL=http://localhost:3200
AUTH_SECRET=your-random-secret-here

# ── OAuth Providers (optional) ───────────────────────────────
GITHUB_ID=your-github-oauth-app-id
GITHUB_SECRET=your-github-oauth-app-secret

GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ── Redis (BullMQ match queue) ───────────────────────────────
# Required for production. If not set, falls back to in-memory queue (local dev).
REDIS_URL=redis://localhost:6379
